# GuardRail configuration (Twelve-Factor). Copy to .env and fill in secrets.
# The application FAILS TO START if required secrets are missing or too weak.
# Generate strong values, e.g.:  openssl rand -base64 48

# ---- Runtime ----
GUARDRAIL_ENV=development           # development | staging | production
VERSION=1.1.2

# ---- Published ports (docker compose) ----
# What the server listens on for the network. Change these here, not in
# docker-compose.yml. HTTPS is the console, the API and brokered sessions, all on
# one port; HTTP only redirects to it.
GUARDRAIL_HTTPS_PORT=443
GUARDRAIL_HTTP_PORT=80

# Where Postgres and Redis are published on the server. 127.0.0.1 keeps them
# reachable for psql and backups but off the network entirely.
# WARNING: setting either BIND_ADDR to 0.0.0.0 exposes the datastore to the LAN.
# The credential vault and every audit record live in Postgres; leave it on
# loopback unless you have a specific reason and a firewall in front of it.
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_ADDR=127.0.0.1
REDIS_PORT=6379

# ---- HTTP ----
# Whose X-Forwarded-For the API believes. This decides the client IP in every
# audit record, so it is a real security setting, not plumbing: trust the wrong
# thing and anyone can forge who they were.
#
# 0.0.0.0/0 is safe *here specifically* because the API's port is never published
# — only Traefik, on the internal Docker network, can reach it at all. If you
# expose the API directly, narrow this to your proxy's CIDR.
GUARDRAIL_TRUST_PROXY_HEADERS=true
GUARDRAIL_TRUSTED_PROXIES=0.0.0.0/0

# Only needed if the console is served from a different origin than the API.
# Under compose they share one origin, so this stays empty. Production refuses
# the "*" wildcard outright.
GUARDRAIL_CORS_ALLOW_ORIGINS=

# ---- Secrets (REQUIRED, >= 32 bytes each) ----
GUARDRAIL_JWT_SIGNING_KEY=CHANGE_ME_generate_a_48_byte_base64_secret_here
# Master key (KEK) for the credential vault's envelope encryption.
GUARDRAIL_MASTER_KEY=CHANGE_ME_generate_a_48_byte_base64_secret_here

# ---- PostgreSQL ----
POSTGRES_USER=guardrail
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser_password
POSTGRES_DB=guardrail
# Password for the least-privilege application login role (used by the API so
# Row-Level Security is enforced; the superuser above is only for migrations).
GUARDRAIL_DB_APP_PASSWORD=CHANGE_ME_app_role_password
# The API builds its own DSN from the values above and the guardrail_app role.
# See the bare-metal section at the bottom if you run the API outside compose.

# ---- Redis ----
# Empty means Redis runs with no password. That is acceptable only because Redis
# is bound to REDIS_BIND_ADDR (loopback) and nothing off-box can reach it; set
# one if you ever move Redis or widen that bind.
REDIS_PASSWORD=

# ---- Primary super admin (bootstrapped from the environment on first boot) ----
# Set/change these BEFORE the first start. On first boot GuardRail creates this
# super admin automatically (idempotent — a no-op on later boots). Leave both
# EMAIL and PASSWORD empty to bootstrap manually with `guardrail seed-admin`.
# The process REFUSES TO START if the password is set but shorter than 12 chars.
# After first boot, rotate it from the console: Account -> Password.
GUARDRAIL_ADMIN_EMAIL=admin@yourco.com
GUARDRAIL_ADMIN_PASSWORD=CHANGE_ME_min_12_chars_before_first_boot
GUARDRAIL_ADMIN_USERNAME=admin
GUARDRAIL_ADMIN_ORG=default

# ---- Session recording ----
# Recording needs browser isolation: the reverse proxy hands the device's own
# HTML to your browser and never sees pixels, so there is nothing to record.
# With this off, a device with recording switched on quietly gets a plain proxy
# session instead — the policy reads as "on" while recording nothing.
GUARDRAIL_BROWSER_ISOLATION=true
# Which Chromium to launch. Blank autodetects chromium / chromium-browser /
# google-chrome from $PATH, which is right under compose (the image installs
# Chromium at /usr/bin/chromium). Set it when the browser is not on $PATH — e.g.
# running the API natively against a Playwright/Puppeteer cached Chromium. If it
# cannot be resolved, the server says so at startup and reports session recording
# as unavailable rather than failing at connect time.
GUARDRAIL_CHROME_PATH=
# Frames are written here, inside the container. Under compose this is the
# `recordings` volume; back it up alongside the database, since it is evidence.
GUARDRAIL_RECORDING_DIR=/var/lib/guardrail/recordings

# ---- Desktop access (RDP / VNC) ----
# RDP and VNC are brokered through guacd, the Apache Guacamole proxy daemon: it
# speaks the desktop protocol to the device and renders it into drawing
# instructions the console paints on a canvas. The device credential goes into
# guacd's connect handshake server-side and never reaches the browser — the same
# guarantee browser isolation gives a web UI.
#
# Off by default: it needs a sidecar, and a deployment with no desktops to broker
# should not run a daemon it never uses. With this off, connecting to an RDP or
# VNC device is refused rather than failing at connect time.
#
# Under compose, turn BOTH of these on together:
#   GUARDRAIL_DESKTOP_ENABLED=true
#   docker compose --profile desktop up -d
GUARDRAIL_DESKTOP_ENABLED=false
# Where guacd listens. Under compose this is the service name on the internal
# network; running the API natively, publish guacd on loopback and use
# 127.0.0.1:4822. Never expose this port to the network: guacd has no
# authentication of its own, so anything that can reach it can ask it to connect
# to any host with any credential.
#GUARDRAIL_GUACD_ADDR=guacd:4822
# Scratch space shared between guacd and the API: guacd writes each session
# recording here, the API moves it into the blob store when the session ends and
# deletes it. Both must be able to see this path.
#
# guacd (uid 1000) writes recordings here 0640 (group-readable); the API joins
# guacd's group (compose group_add: "1000") to read them back. So the directory is
# owned by guacd and setgid. If you change this path, create it yourself:
#
#   sudo mkdir -p <path>
#   sudo chown 1000:1000 <path> && sudo chmod 2770 <path>
#
# Leave it to Docker and Docker creates the bind-mount source as root:root 755,
# which guacd cannot write to. It does not fail loudly when that happens: it logs
# the error and serves the desktop anyway, so the session works perfectly and
# records nothing. `make install` sets this up for the default path.
#GUARDRAIL_GUACD_RECORDING_DIR=/var/lib/guardrail/desktop-recordings
# The desktop size requested of the device. The console rescales to fit the
# window; this is the resolution the device itself is asked to render.
#GUARDRAIL_DESKTOP_WIDTH=1280
#GUARDRAIL_DESKTOP_HEIGHT=800

# ---- Logging ----
GUARDRAIL_LOG_LEVEL=info            # debug | info | warn | error
GUARDRAIL_LOG_FORMAT=json           # json | console


# ===========================================================================
# OPTIONAL — everything below is off, and the built-in default is what runs.
#
# These are commented out rather than set to their defaults on purpose: an
# assignment here is indistinguishable from a deliberate choice, and a file full
# of restated defaults hides the handful of values that actually matter. Every
# key is already wired through docker-compose.yml, so uncommenting one is enough
# to make it take effect — no compose edit needed.
# ===========================================================================

# ---- Tokens ----
# How long an access token, then a sign-in, stays valid.
#GUARDRAIL_ACCESS_TOKEN_TTL=15m
#GUARDRAIL_REFRESH_TOKEN_TTL=720h

# ---- Federation: OIDC / LDAP sign-in ----
# All providers stay disabled unless GUARDRAIL_FEDERATION_ORG_ID names the
# organization federated users are provisioned into. Set it first.
#GUARDRAIL_FEDERATION_ORG_ID=

# OIDC (Authorization Code + PKCE). Active once issuer + client id + redirect
# are all set. The redirect is where the BROWSER is sent back to, so it must be
# the console's public URL — scheme, host and GUARDRAIL_HTTPS_PORT — not the
# internal API port, and your identity provider must allow it exactly.
#GUARDRAIL_OIDC_ISSUER=
#GUARDRAIL_OIDC_CLIENT_ID=
#GUARDRAIL_OIDC_CLIENT_SECRET=
#GUARDRAIL_OIDC_REDIRECT_URL=https://guardrail.yourco.com/api/v1/auth/oidc/callback

# LDAP / Active Directory (search-then-bind). Active once url + base DN are set.
#
# Keep these hints on their own lines. A trailing "# comment" after an EMPTY
# value is not stripped by the compose .env parser — it becomes the value — so
# `GUARDRAIL_LDAP_URL=   # ldap://host:389` would hand the API the literal
# string "# ldap://host:389" and fail in a thoroughly confusing way.
#
# ldap://host:389 or ldaps://host:636
#GUARDRAIL_LDAP_URL=
# Service account DN for the user search.
#GUARDRAIL_LDAP_BIND_DN=
#GUARDRAIL_LDAP_BIND_PASSWORD=
# e.g. ou=people,dc=corp,dc=com
#GUARDRAIL_LDAP_BASE_DN=
# e.g. (uid=%s) or (sAMAccountName=%s)
#GUARDRAIL_LDAP_USER_FILTER=

# ---- Tracing ----
# Empty disables trace export entirely; set an OTLP collector endpoint to turn
# it on. SERVICE_NAME only labels the exported spans.
#GUARDRAIL_OTLP_ENDPOINT=
#GUARDRAIL_SERVICE_NAME=guardrail-api

# ---- Running the API outside compose (bare metal / `make run`) ----
# docker compose sets all four of these itself, from the service names and ports
# on the internal network, and ignores whatever is here — so they are commented
# out to avoid looking like live settings that do nothing. They matter only when
# you run the Go binary directly (DEPLOYMENT.md, "Local development").
#GUARDRAIL_HTTP_ADDR=:8080
#GUARDRAIL_METRICS_ADDR=:9090
#GUARDRAIL_REDIS_ADDR=localhost:6379
# Point this at whatever POSTGRES_PORT you published above.
#GUARDRAIL_POSTGRES_DSN=postgres://guardrail:CHANGE_ME_postgres_superuser_password@localhost:5432/guardrail?sslmode=disable
